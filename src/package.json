{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "lint": "eslint resources/ts --ext .ts,.vue",
        "format": "prettier --write resources/ts resources/css",
        "format:check": "prettier --check resources/ts resources/css",
        "test": "vitest"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^25.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/test-utils": "^2.4.10",
        "axios": "^1.11.0",
        "eslint": "^10.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^2.1.0",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.6"
    },
    "dependencies": {
        "@vueuse/core": "^14.2.1",
        "marked": "^17.0.5",
        "vue": "^3.5.31",
        "vue-router": "^5.0.4"
    }
}
